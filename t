&НаКлиенте
Процедура РассчитатьПлан(Команда)
	РассчитатьПланНаСервере();
КонецПроцедуры


&НаСервере
Процедура РассчитатьПланНаСервере()
    Объект.Расписание.Очистить();
    
    ТаблицаЗанятости = Новый ТаблицаЗначений;
    ТаблицаЗанятости.Колонки.Добавить("РабочийЦентр");
    ТаблицаЗанятости.Колонки.Добавить("Начало");
    ТаблицаЗанятости.Колонки.Добавить("Конец");
    ТаблицаЗанятости.Колонки.Добавить("Цвет");
    
    Объект.Заказы.Сортировать("ДатаСдачи Возр");
    
    Для Каждого СтрокаЗаказа Из Объект.Заказы Цикл
        
        ТекущийДедлайн = СтрокаЗаказа.ДатаСдачи;
        
        Запрос = Новый Запрос;
        Запрос.Текст = 
            "ВЫБРАТЬ
            |   ТехОперации.Ссылка КАК Операция,
            |   ТехОперации.ВидОперации КАК ВидОперации,
            |   ТехОперации.Длительность КАК Длительность,
            |   ТехОперации.ТребуемыйРЦ КАК ТребуемыйРЦ
            |ИЗ
            |   Справочник.ТехОперации КАК ТехОперации
            |ГДЕ
            |   ТехОперации.Владелец = &Номенклатура
            |УПОРЯДОЧИТЬ ПО
            |   ТехОперации.ПорядковыйНомер УБЫВ";
            
        Запрос.УстановитьПараметр("Номенклатура", СтрокаЗаказа.Номенклатура);
        Выборка = Запрос.Выполнить().Выбрать();
        
        Пока Выборка.Следующий() Цикл
            
            ВремяНаПартию = Выборка.Длительность * СтрокаЗаказа.Количество * 60;
            
            Если ЗначениеЗаполнено(Выборка.ТребуемыйРЦ) Тогда
                НужныйРЦ = Выборка.ТребуемыйРЦ;
            Иначе
                НужныйРЦ = НайтиПодходящийРЦ(Выборка.ВидОперации);
            КонецЕсли;
            
            Интервал = НайтиСвободноеОкно(НужныйРЦ, ВремяНаПартию, ТекущийДедлайн, ТаблицаЗанятости, СтрокаЗаказа.Цвет);
            
            НоваяСтрока = Объект.Расписание.Добавить();
            НоваяСтрока.Номенклатура = СтрокаЗаказа.Номенклатура;
            НоваяСтрока.Цвет         = СтрокаЗаказа.Цвет;
            НоваяСтрока.Операция     = Выборка.Операция;
            НоваяСтрока.РабочийЦентр = НужныйРЦ;
            НоваяСтрока.Начало       = Интервал.Начало;
            НоваяСтрока.Конец        = Интервал.Конец;
            
            СтрЗан = ТаблицаЗанятости.Добавить();
            СтрЗан.РабочийЦентр = НужныйРЦ;
            СтрЗан.Начало       = Интервал.Начало;
            СтрЗан.Конец        = Интервал.Конец;
            СтрЗан.Цвет         = СтрокаЗаказа.Цвет;
            
            ТекущийДедлайн = Интервал.Начало;
            
        КонецЦикла;
    КонецЦикла;
    
    ОбновитьДиаграмму();
КонецПроцедуры

&НаСервере
Функция НайтиСвободноеОкно(РЦ, ДлительностьСек, Дедлайн, ТаблицаЗанятости, НашЦвет)
    
        ПотенциальныйКонец = Дедлайн;
    ВремяМойки = 0;
    
    Если РЦ.ВидОперации = Перечисления.ВидыОпераций.Покраска Тогда
         ВремяМойки = РЦ.ВремяВыполнения * 60;    КонецЕсли;
    
    Пока Истина Цикл
        
        ПотенциальноеНачало = ПотенциальныйКонец - ДлительностьСек;
        ПринудительныйСдвиг = Ложь;
        
        Конфликт = НайтиПересечение(РЦ, ПотенциальноеНачало, ПотенциальныйКонец, ТаблицаЗанятости);
        
        Если Конфликт <> Неопределено Тогда
            ПотенциальныйКонец = Конфликт.Начало;
            
            Если РЦ.ВидОперации = Перечисления.ВидыОпераций.Покраска 
                И Конфликт.Цвет <> НашЦвет Тогда
                ПотенциальныйКонец = ПотенциальныйКонец - ВремяМойки;
            КонецЕсли;
            
            ПринудительныйСдвиг = Истина;
        КонецЕсли;
        
        Если НЕ ПринудительныйСдвиг И ВремяМойки > 0 Тогда
            
            Для Каждого СтрЗан Из ТаблицаЗанятости Цикл
                
                Если СтрЗан.РабочийЦентр = РЦ И СтрЗан.Цвет <> НашЦвет Тогда
                    
                    Разрыв = СтрЗан.Начало - ПотенциальныйКонец;
                    
                    Если Разрыв >= 0 И Разрыв < ВремяМойки Тогда
                        ПотенциальныйКонец = СтрЗан.Начало - ВремяМойки;
                        ПринудительныйСдвиг = Истина;
                        Прервать;                    КонецЕсли;
                    
                КонецЕсли;
                
            КонецЦикла;
            
        КонецЕсли;
        
        Если НЕ ПринудительныйСдвиг Тогда
            Возврат Новый Структура("Начало, Конец", ПотенциальноеНачало, ПотенциальныйКонец);
        КонецЕсли;
        
    КонецЦикла;
    
КонецФункции

&НаСервере
Функция НайтиПересечение(РЦ, Начало, Конец, ТаблицаЗанятости)
    
    Отбор = Новый Структура("РабочийЦентр", РЦ);
    СтрокиРЦ = ТаблицаЗанятости.НайтиСтроки(Отбор);
    
    Для Каждого Стр Из СтрокиРЦ Цикл
        Если Начало < Стр.Конец И Конец > Стр.Начало Тогда
            Возврат Стр;         КонецЕсли;
    КонецЦикла;
    
    Возврат Неопределено;
    
КонецФункции

&НаСервере
Процедура ОбновитьДиаграмму()
    
    ДиаграммаПланирования.Очистить();
    ДиаграммаПланирования.Обновление = Ложь;
    ДиаграммаПланирования.ЕдиницаПериодическогоВарианта = ТипЕдиницыШкалыВремени.Час;
    
    ТочкиРЦ = Новый Соответствие;
    
    Для Каждого Стр Из Объект.Расписание Цикл
        
        РЦ = Стр.РабочийЦентр;
        
        Если ТочкиРЦ[РЦ] = Неопределено Тогда
            Точка = ДиаграммаПланирования.Точки.Добавить(); 
			Точка.Значение = РЦ; 
            Точка.Текст = РЦ.Наименование;
            ТочкиРЦ.Вставить(РЦ, Точка);
        КонецЕсли;
        
    КонецЦикла;
    
    Серия = ДиаграммаПланирования.Серии.Добавить();
    Серия.Текст = "План";
    
    Для Каждого Стр Из Объект.Расписание Цикл
        
        Точка = ТочкиРЦ[Стр.РабочийЦентр];

        Значение = ДиаграммаПланирования.ПолучитьЗначение(Точка, Серия);
        
        Интервал = Значение.Добавить();
        Интервал.Начало = Стр.Начало;
        Интервал.Конец  = Стр.Конец;
        
        Интервал.Текст = "" + Стр.Номенклатура + " (" + Стр.Операция.ВидОперации + ")";
        
        Если Стр.Цвет = Перечисления.Цвета.Синий Тогда
            Интервал.Цвет = WebЦвета.Синий;
            Интервал.ЦветТекста = WebЦвета.Белый;
            
        ИначеЕсли Стр.Цвет = Перечисления.Цвета.Зеленый Тогда
            Интервал.Цвет = WebЦвета.Зеленый;
            Интервал.ЦветТекста = WebЦвета.Черный;
            
        ИначеЕсли Стр.Цвет = Перечисления.Цвета.Белый Тогда
            Интервал.Цвет = WebЦвета.Gainsboro;
            Интервал.ЦветТекста = WebЦвета.Черный; 
            
        ИначеЕсли Стр.Цвет = Перечисления.Цвета.Черный Тогда
            Интервал.Цвет = WebЦвета.Черный;
            Интервал.ЦветТекста = WebЦвета.Белый; 
            
        Иначе
            Интервал.Цвет = WebЦвета.Серый;
            Интервал.ЦветТекста = WebЦвета.Черный;
        КонецЕсли;
        
    КонецЦикла;
    
    ДиаграммаПланирования.Обновление = Истина;
    
КонецПроцедуры

&НаСервере
Функция НайтиПодходящийРЦ(ВидОперации)
    Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.РабочиеЦентры ГДЕ ВидОперации = &Вид";
    Запрос.УстановитьПараметр("Вид", ВидОперации);
    Результат = Запрос.Выполнить();
    Если Не Результат.Пустой() Тогда
        Возврат Результат.Выгрузить()[0].Ссылка;
    КонецЕсли;
    Возврат Справочники.РабочиеЦентры.ПустаяСсылка();
КонецФункции
